{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "version": "1.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "{f6190d00-0fd9-4886-9509-9254e69f4649}",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "menus",
    "tabs",
    "messagesRead",
    "accountsRead",
    "messagesMove",
    "messagesDelete",
    "storage"
  ],
  "background": {
  "scripts": ["settings.js", "background.js"]
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  
  "browser_action": {
    "default_title": "__MSG_removeDuplicateMenu__"
  },

  "commands": {
    "run-duplicate-scan": {
      "suggested_key": {
        "default": "Ctrl+Shift+D"
      },
    "description": "__MSG_runDuplicateScanCommand__"
    }
  }

}
