{
  "manifest_version": 2,
  "name": "WebAwesome-Table-Example",
  "version": "1.0",
  "description": "Demonstrates WebAwesome UI in TB WebExtension",
  "applications": {
    "gecko": {
      "id": "web-awesome-table-example@example.thunderbird.net"
    }
  },
  "permissions": [
    "menus",
    "tabs",
    "messagesRead",
    "accountsRead",
    "messagesMove",
    "messagesDelete",
    "storage"
  ],
  "background": {
  "scripts": ["settings.js", "background.js"]
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  
  "browser_action": {
    "default_title": "Remove Duplicate Messages"
  }
}
